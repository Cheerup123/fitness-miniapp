<view class="timer-container" wx:if="{{visible}}">
  <view class="timer-overlay" bindtap="onClose"></view>
  <view class="timer-panel">
    <view class="timer-title">组间休息</view>
    <view class="timer-display">
      <text class="timer-minutes">{{displayMinutes}}</text>
      <text class="timer-separator">:</text>
      <text class="timer-seconds">{{displaySeconds}}</text>
    </view>
    
    <!-- 进度环 -->
    <view class="progress-ring">
      <view class="ring-bg"></view>
      <view class="ring-progress" style="background: conic-gradient(#FF6B35 {{progressPercent}}%, transparent {{progressPercent}}%);"></view>
      <view class="ring-inner"></view>
    </view>

    <view class="timer-controls">
      <view class="timer-btn timer-btn-reset" bindtap="onReset">
        <text>重置</text>
      </view>
      <view class="timer-btn timer-btn-{{running ? 'pause' : 'start'}}" bindtap="onToggle">
        <text>{{running ? '暂停' : '开始'}}</text>
      </view>
      <view class="timer-btn timer-btn-skip" bindtap="onSkip">
        <text>跳过</text>
      </view>
    </view>

    <view class="timer-presets">
      <text class="preset-label">快捷设置:</text>
      <view class="preset-item {{item === totalSeconds ? 'active' : ''}}" 
            wx:for="{{presets}}" wx:key="*this" 
            bindtap="onPreset" data-seconds="{{item}}">
        <text>{{item}}秒</text>
      </view>
    </view>
  </view>
</view>
