.exercise-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-left {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.exercise-image {
  width: 100%;
  height: 100%;
  background: #F0F0F5;
}

.type-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 8rpx 12rpx;
  text-align: center;
}

.type-badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.exercise-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exercise-name-en {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.exercise-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.exercise-parts {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.part-tag {
  font-size: 20rpx;
  color: #666666;
  background: #F5F5FA;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.exercise-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.sets-info {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B35;
}

.rest-info {
  font-size: 22rpx;
  color: #999999;
}

.card-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}
