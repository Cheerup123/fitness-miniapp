/* 全局样式 */
page {
  background-color: #F5F5FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1A1A2E;
  line-height: 1.5;
}

/* 主色变量 */
view {
  --primary-color: #FF6B35;
  --primary-light: #FF8F65;
  --primary-dark: #E55A2B;
  --secondary-color: #1A1A2E;
  --bg-color: #F5F5FA;
  --card-bg: #FFFFFF;
  --success-color: #4CAF50;
  --warning-color: #FF9800;
  --danger-color: #F44336;
  --text-primary: #1A1A2E;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #EEEEEE;
  --card-radius: 16rpx;
  --btn-radius: 8rpx;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #FF6B35, #FF8F65);
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #FFFFFF;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}

.tag-success {
  background: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.tag-warning {
  background: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.tag-info {
  background: rgba(33, 150, 243, 0.1);
  color: #2196F3;
}

/* 文本省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* Flex布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-16 { margin-left: 16rpx; }
.mr-16 { margin-right: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #EEEEEE;
  margin: 24rpx 0;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
