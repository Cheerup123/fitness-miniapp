.container { padding: 24rpx; padding-bottom: 40rpx; }
.month-stats { padding: 32rpx; }
.stats-grid { display: flex; justify-content: space-around; margin-top: 16rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-value { font-size: 44rpx; font-weight: 700; color: #FF6B35; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.history-list { margin-top: 16rpx; }
.history-item { padding: 28rpx 32rpx; }
.item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.item-date { display: flex; align-items: baseline; gap: 12rpx; }
.date-day { font-size: 30rpx; font-weight: 600; color: #1A1A2E; }
.date-week { font-size: 24rpx; color: #999; }
.item-stats { display: flex; gap: 32rpx; margin-bottom: 16rpx; }
.item-stat { display: flex; align-items: center; gap: 8rpx; }
.item-stat-icon { font-size: 28rpx; }
.item-stat-value { font-size: 26rpx; color: #666; }
.item-feeling { font-size: 24rpx; color: #999; padding-top: 12rpx; border-top: 1rpx solid #F5F5FA; }
.loading-more { display: flex; justify-content: center; padding: 32rpx; }
.no-more { text-align: center; padding: 32rpx; font-size: 24rpx; color: #CCC; }
