.workout-page {
  min-height: 100vh;
  background: #F5F5FA;
  padding-bottom: 40rpx;
}

/* 计时栏 */
.timer-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #1A1A2E;
  color: #FFFFFF;
}

.timer-left {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.timer-text {
  font-size: 56rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.timer-text.paused {
  color: #FF9800;
}

.timer-label {
  font-size: 24rpx;
  color: #FF9800;
}

.timer-actions {
  display: flex;
  gap: 24rpx;
}

.timer-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.finish-btn {
  background: rgba(76, 175, 80, 0.3);
}

/* 进度条 */
.progress-bar {
  padding: 20rpx 32rpx;
  background: #FFFFFF;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.progress-track {
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #FF8F65);
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 动作切换标签 */
.exercise-tabs {
  white-space: nowrap;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.exercise-tab {
  display: inline-block;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  background: #F5F5FA;
  text-align: center;
  min-width: 120rpx;
}

.exercise-tab.active {
  background: rgba(255, 107, 53, 0.1);
  border: 2rpx solid #FF6B35;
}

.exercise-tab.done {
  background: rgba(76, 175, 80, 0.1);
}

.tab-name {
  display: block;
  font-size: 24rpx;
  color: #1A1A2E;
  font-weight: 500;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tab-count {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 当前动作 */
.current-exercise {
  padding: 32rpx;
}

.exercise-header {
  margin-bottom: 24rpx;
}

.exercise-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}

.exercise-target {
  font-size: 26rpx;
  color: #FF6B35;
}

/* 已完成组列表 */
.sets-list {
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.sets-header {
  display: flex;
  padding: 16rpx 24rpx;
  background: #F5F5FA;
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

.set-row {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F5F5FA;
  align-items: center;
}

.set-row.latest {
  background: rgba(255, 107, 53, 0.03);
}

.set-col {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.set-num {
  font-weight: 600;
  color: #FF6B35;
}

/* 输入区域 */
.set-input-area {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.set-input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.set-input-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B35;
}

.input-row {
  display: flex;
  gap: 24rpx;
}

.input-group {
  flex: 1;
}

.input-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.set-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5FA;
  border-radius: 12rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  box-sizing: border-box;
  padding: 0 16rpx;
}

/* 动作导航 */
.nav-buttons {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 16rpx;
}

/* 空状态 */
.empty-workout {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 休息弹窗 */
.rest-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.rest-card {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
}

.rest-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 32rpx;
}

.rest-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 8rpx solid #FF6B35;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.rest-time {
  font-size: 80rpx;
  font-weight: 700;
  color: #FF6B35;
}

.rest-unit {
  font-size: 24rpx;
  color: #999;
}

.rest-progress {
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.rest-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #FF8F65);
  border-radius: 4rpx;
  transition: width 1s linear;
}

.rest-actions {
  display: flex;
  justify-content: center;
}

/* 训练感受弹窗 */
.feeling-sheet {
  padding: 48rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.feeling-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

.feeling-options {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.feeling-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.feeling-item.selected {
  background: rgba(255, 107, 53, 0.1);
  transform: scale(1.1);
}

.feeling-emoji {
  font-size: 48rpx;
}

.feeling-label {
  font-size: 22rpx;
  color: #666;
}

.feeling-item.selected .feeling-label {
  color: #FF6B35;
  font-weight: 500;
}
