.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chat-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.date-header {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 20rpx 0;
}

.message-list {
  display: flex;
  flex-direction: column;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-content {
  max-width: 500rpx;
  margin: 0 20rpx;
}

.message-text {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}

.message.assistant .message-text {
  background: #fff;
  color: #333;
}

.message.user .message-text {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.message.user .message-time {
  text-align: right;
}

.loading-tip {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

.quick-actions {
  position: fixed;
  bottom: 160rpx;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(to top, #f5f5f5 80%, transparent);
}

.quick-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.quick-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.quick-btn {
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #667eea;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.chat-input {
  flex: 1;
  height: 70rpx;
  padding: 0 30rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #ddd;
  color: #fff;
  border-radius: 35rpx;
  font-size: 26rpx;
  padding: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
