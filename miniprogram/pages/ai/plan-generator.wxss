.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.step-area {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.slider-value {
  text-align: center;
  font-size: 32rpx;
  color: #667eea;
  font-weight: 500;
  margin-top: 16rpx;
}

.picker-value {
  padding: 20rpx 30rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.equipment-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.equipment-item {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.equipment-item.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-area {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.next-btn, .confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.back-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.generating {
  text-align: center;
  padding: 60rpx 0;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #f5f5f5;
  border-top-color: #667eea;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.generating-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.generating-tip {
  font-size: 26rpx;
  color: #999;
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.result-subtitle {
  font-size: 28rpx;
  color: #667eea;
  margin-top: 10rpx;
}

.explanation-card {
  background: #f8f8fa;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-line;
}

.plan-preview {
  margin-top: 30rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.day-item {
  background: #f8f8fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.day-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.day-rest {
  font-size: 24rpx;
  color: #999;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.exercise-item {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
}

.ex-name {
  color: #666;
}

.ex-detail {
  color: #999;
}

.plan-name-input {
  margin-top: 30rpx;
}

.name-input {
  padding: 20rpx 30rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.success-card {
  text-align: center;
  padding: 60rpx 0;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 60rpx;
  border-radius: 50%;
  margin: 0 auto 30rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.success-tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
