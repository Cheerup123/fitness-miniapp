<view class="container">
  <!-- 基本信息 -->
  <view class="card">
    <view class="section-title">👤 基本信息</view>
    <van-cell-group>
      <van-field label="昵称" value="{{nickname}}" placeholder="输入昵称"
                 bindinput="onNicknameInput" maxlength="20" />
      <van-field label="性别" value="{{gender === 1 ? '男' : gender === 2 ? '女' : '未设置'}}"
                 placeholder="选择性别" readonly bindtap="onShowGenderPicker" right-icon="arrow" />
      <van-field label="生日" value="{{birthday}}" placeholder="选择生日"
                 readonly bindtap="onShowDatePicker" right-icon="arrow" />
    </van-cell-group>
  </view>

  <!-- 身体数据 -->
  <view class="card">
    <view class="section-title">📏 身体数据</view>
    <van-cell-group>
      <van-field label="身高(cm)" type="digit" value="{{height}}" placeholder="如 175"
                 bindinput="onHeightInput" />
      <van-field label="当前体重(kg)" type="digit" value="{{weight}}" placeholder="如 70"
                 bindinput="onWeightInput" />
      <van-field label="目标体重(kg)" type="digit" value="{{targetWeight}}" placeholder="如 65"
                 bindinput="onTargetWeightInput" />
    </van-cell-group>
  </view>

  <!-- 健身目标 -->
  <view class="card">
    <view class="section-title">🎯 健身目标</view>
    <view class="goal-grid">
      <view class="goal-item {{fitnessGoal === item.value ? 'active' : ''}}"
            wx:for="{{fitnessGoals}}" wx:key="value"
            bindtap="onGoalConfirm" data-value="{{item.value}}">
        <text class="goal-icon">{{item.icon}}</text>
        <text class="goal-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 健身水平 -->
  <view class="card">
    <view class="section-title">📊 健身水平</view>
    <view class="level-options">
      <view class="level-item {{fitnessLevel === item.value ? 'active' : ''}}"
            wx:for="{{fitnessLevels}}" wx:key="value"
            bindtap="onLevelConfirm" data-value="{{item.value}}">
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 训练偏好 -->
  <view class="card">
    <view class="section-title">⏰ 训练偏好</view>
    <view class="pref-row">
      <text class="pref-label">每周训练天数</text>
      <van-stepper value="{{workoutDays}}" min="1" max="7" bind:change="onWorkoutDaysChange"
                   integer="{{true}}" input-width="80rpx" />
    </view>
    <view class="pref-row">
      <text class="pref-label">每次时长(分钟)</text>
      <van-stepper value="{{workoutDuration}}" min="15" max="120" step="5"
                   bind:change="onWorkoutDurationChange" integer="{{true}}" input-width="80rpx" />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="submit-area">
    <van-button type="primary" block round
                custom-style="background: linear-gradient(135deg, #FF6B35, #FF8F65); border: none; height: 88rpx;"
                bindtap="onSubmit">保存</van-button>
  </view>
</view>
