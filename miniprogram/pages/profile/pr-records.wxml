<view class="container">
  <!-- PR列表 -->
  <view class="pr-list" wx:if="{{prList.length > 0}}">
    <view class="pr-card card" wx:for="{{prList}}" wx:key="id" bindtap="goExerciseDetail" data-id="{{item.id}}">
      <image class="exercise-img" src="{{item.demo_image_url || '/images/exercise-default.png'}}" mode="aspectFill"/>
      <view class="pr-info">
        <view class="exercise-name">{{item.name}}</view>
        <view class="pr-stats">
          <view class="pr-stat">
            <text class="stat-value">{{item.max_weight || '-'}}</text>
            <text class="stat-label">最大重量(kg)</text>
          </view>
          <view class="pr-stat">
            <text class="stat-value">{{item.max_reps || '-'}}</text>
            <text class="stat-label">最大次数</text>
          </view>
          <view class="pr-stat">
            <text class="stat-value">{{item.max_volume ? item.max_volume.toFixed(1) : '-'}}</text>
            <text class="stat-label">最大容量</text>
          </view>
        </view>
        <view class="last-date" wx:if="{{item.last_date}}">
          <van-icon name="clock-o" size="12px" color="#999"/>
          <text>最近训练: {{formatDate(item.last_date)}}</text>
        </view>
      </view>
      <van-icon name="arrow" color="#CCCCCC"/>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state wx:else icon="🏆" title="暂无PR记录" description="开始训练，创造你的个人最佳！"></empty-state>
</view>
