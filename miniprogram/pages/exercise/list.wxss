.container { padding-bottom: 40rpx; }
.filter-bar { display: flex; gap: 16rpx; padding: 16rpx 24rpx; background: #FFF; overflow-x: auto; white-space: nowrap; }
.filter-tag { padding: 10rpx 24rpx; border-radius: 32rpx; background: #F5F5FA; font-size: 24rpx; color: #666; flex-shrink: 0; }
.filter-tag.active { background: rgba(255,107,53,0.1); color: #FF6B35; font-weight: 500; }
.exercise-list { padding: 16rpx 24rpx; }
.exercise-item { display: flex; align-items: center; padding: 24rpx; background: #FFF; border-radius: 16rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.ex-icon { width: 100rpx; height: 100rpx; border-radius: 12rpx; background: #F5F5FA; overflow: hidden; margin-right: 24rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.ex-icon image { width: 100%; height: 100%; }
.ex-icon-text { font-size: 48rpx; }
.ex-info { flex: 1; }
.ex-name { font-size: 30rpx; font-weight: 600; color: #1A1A2E; display: block; margin-bottom: 8rpx; }
.ex-tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
