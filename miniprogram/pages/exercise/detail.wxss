.container { padding: 0 0 40rpx; }
.demo-area { width: 100%; height: 480rpx; background: #1A1A2E; position: relative; }
.demo-img { width: 100%; height: 100%; }
.demo-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.demo-icon { font-size: 120rpx; }
.favorite-btn { position: absolute; top: 24rpx; right: 24rpx; width: 72rpx; height: 72rpx; border-radius: 50%; background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; }
.info-card { margin: -40rpx 24rpx 0; position: relative; z-index: 1; }
.ex-name { font-size: 40rpx; font-weight: 700; color: #1A1A2E; display: block; margin-bottom: 8rpx; }
.ex-name-en { font-size: 26rpx; color: #999; display: block; margin-bottom: 16rpx; }
.ex-tags { display: flex; gap: 12rpx; flex-wrap: wrap; }
.card { margin: 16rpx 24rpx; background: #FFF; border-radius: 16rpx; padding: 32rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #1A1A2E; margin-bottom: 24rpx; }
.muscle-list { display: flex; flex-direction: column; gap: 16rpx; }
.muscle-item { display: flex; justify-content: space-between; align-items: center; }
.muscle-name { font-size: 28rpx; color: #333; }
.desc-text { font-size: 28rpx; color: #666; line-height: 1.8; }
.step-list { display: flex; flex-direction: column; gap: 20rpx; }
.step-item { display: flex; gap: 16rpx; }
.step-num { width: 48rpx; height: 48rpx; border-radius: 50%; background: #FF6B35; color: #FFF; font-size: 24rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-text { font-size: 28rpx; color: #333; line-height: 1.6; }
.tip-list { display: flex; flex-direction: column; gap: 12rpx; }
.tip-item { display: flex; gap: 12rpx; }
.tip-dot { color: #FF6B35; font-size: 28rpx; }
.tip-text { font-size: 28rpx; color: #666; line-height: 1.6; }
