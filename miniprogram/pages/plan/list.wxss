.container {
  padding-bottom: 40rpx;
}

.filter-tabs {
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.goal-filter {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.goal-item {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  background: #F5F5FA;
  flex-shrink: 0;
}

.goal-item.active {
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
  font-weight: 500;
}

.plan-list {
  padding: 0 24rpx;
}

.plan-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.plan-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.plan-cover image {
  width: 100%;
  height: 100%;
}

.plan-info {
  flex: 1;
  min-width: 0;
}

.plan-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.plan-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.plan-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999999;
}

.plan-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}
