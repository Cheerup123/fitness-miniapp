<view class="container">
  <!-- 顶部问候 -->
  <view class="header">
    <view class="greeting">
      <text class="greeting-text">{{greeting}}，{{userInfo.nickname || '健身达人'}}</text>
      <view class="streak-badge" wx:if="{{streakDays > 0}}">
        <text>🔥 连续训练 {{streakDays}} 天</text>
      </view>
    </view>
    <view class="header-avatar" bindtap="goProfile">
      <image src="{{userInfo.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
  </view>

  <!-- 今日计划卡片 -->
  <view class="today-plan card" wx:if="{{todayPlan}}" bindtap="goPlanDetail" data-id="{{todayPlan.planId}}">
    <view class="plan-header">
      <view class="plan-tag">📅 今日计划</view>
      <view class="plan-name">{{todayPlan.dayLabel || '训练日'}}</view>
    </view>
    <view class="plan-exercises">
      <view class="plan-exercise-item" wx:for="{{todayPlan.exercises}}" wx:key="exercise_id" wx:if="{{index < 4}}">
        <text class="ex-name">{{item.exercise_name}}</text>
        <text class="ex-detail">{{item.sets}}×{{item.reps || '-'}}</text>
      </view>
      <view class="plan-more" wx:if="{{todayPlan.exercises.length > 4}}">
        <text>还有 {{todayPlan.exercises.length - 4}} 个动作...</text>
      </view>
    </view>
    <view class="plan-action">
      <van-button type="primary" round block custom-style="background: linear-gradient(135deg, #FF6B35, #FF8F65); border: none; height: 80rpx; font-size: 30rpx;">
        开始训练
      </van-button>
    </view>
  </view>

  <!-- 无今日计划 -->
  <view class="today-plan card" wx:else>
    <view class="plan-header">
      <view class="plan-tag">📅 今日计划</view>
    </view>
    <empty-state icon="📋" title="暂无训练计划" description="选择一个训练计划开始吧" buttonText="查看计划" bind:action="goPlanList"></empty-state>
  </view>

  <!-- 本周概览 -->
  <view class="week-overview card">
    <view class="section-title">📊 本周概览</view>
    <view class="week-days">
      <view class="week-day {{item.isToday ? 'today' : ''}} {{item.checked ? 'checked' : ''}}" 
            wx:for="{{weekDates}}" wx:key="date">
        <text class="day-label">周{{item.day}}</text>
        <view class="day-dot">
          <text wx:if="{{item.checked}}">✅</text>
          <text wx:elif="{{item.isToday}}">📍</text>
        </view>
      </view>
    </view>
    <view class="week-stats">
      <view class="week-stat">
        <text class="stat-num">{{weekWorkoutCount}}</text>
        <text class="stat-label">本周训练</text>
      </view>
      <view class="week-stat">
        <text class="stat-num">{{totalWorkoutCount}}</text>
        <text class="stat-label">累计训练</text>
      </view>
      <view class="week-stat">
        <text class="stat-num">{{totalDuration}}</text>
        <text class="stat-label">总时长(分)</text>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="quick-actions card">
    <view class="section-title">⚡ 快速入口</view>
    <view class="action-grid">
      <view class="action-item" bindtap="goBodyRecord">
        <view class="action-icon">⚖️</view>
        <text class="action-text">记录体重</text>
      </view>
      <view class="action-item" bindtap="goExerciseList">
        <view class="action-icon">💪</view>
        <text class="action-text">动作库</text>
      </view>
      <view class="action-item" bindtap="goWorkoutHistory">
        <view class="action-icon">📋</view>
        <text class="action-text">训练历史</text>
      </view>
      <view class="action-item" bindtap="goBodyIndex">
        <view class="action-icon">📈</view>
        <text class="action-text">身体数据</text>
      </view>
    </view>
  </view>

  <!-- 今日打卡 -->
  <view class="checkin-card card" wx:if="{{!todayCheckedIn}}" bindtap="onCheckin">
    <view class="checkin-content">
      <text class="checkin-icon">🎯</text>
      <view class="checkin-info">
        <text class="checkin-title">今日打卡</text>
        <text class="checkin-desc">完成训练后别忘了打卡哦</text>
      </view>
    </view>
    <van-button type="primary" size="small" round custom-style="background: #FF6B35; border-color: #FF6B35;">打卡</van-button>
  </view>
</view>
